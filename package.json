{
  "name": "altstack",
  "private": true,
  "license": "MIT",
  "scripts": {
    "build": "turbo run build",
    "changeset": "changeset",
    "changeset:status": "changeset status --since=origin/main",
    "dev": "turbo run dev",
    "lint": "oxlint packages apps examples",
    "lint:fix": "oxlint packages apps examples --fix",
    "format": "oxlint packages apps examples --fix",
    "format:check": "oxlint packages apps examples",
    "check-types": "turbo run check-types",
    "release": "pnpm build && changeset publish",
    "version-packages": "changeset version"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "oxlint": "^1.24.0",
    "turbo": "^2.5.8",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@10.27.0",
  "engines": {
    "node": ">=18"
  }
}
