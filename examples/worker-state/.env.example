# Local API
PORT_API=3005
NODE_ENV=development

# Queue state storage
CLICKHOUSE_URL=http://clickhouse:8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=task-example-clickhouse
CLICKHOUSE_TABLE_PREFIX=task_queue_example

# Shared local application data
SQLITE_PATH=/data/task-queue-example.db
DEFAULT_REDRIVE_BUDGET=1

# Dispatcher
DISPATCH_INTERVAL_MS=1000

# Local Kafka transport
# Default is the in-compose broker address. When running the apps on the host,
# switch this to `localhost:19092`.
KAFKA_BROKERS=kafka:9092
KAFKA_USERNAME=
KAFKA_PASSWORD=
KAFKA_SSL=false
KAFKA_GROUP_ID=task-queue-example-workers

# Set to true to skip environment variable validation
# SKIP_ENV_VALIDATION=false
