{
  "name": "real-life-example",
  "private": true,
  "scripts": {
    "dev": "pnpm -r run dev",
    "build": "pnpm -r run build",
    "generate:all": "pnpm --filter @real-life/backend-auth generate && pnpm --filter @real-life/backend-logic generate && pnpm --filter @real-life/workers generate",
    "lint": "oxlint . --ignore-pattern 'packages/*-sdk/src/index.ts' --deny-warnings",
    "lint:fix": "oxlint . --fix",
    "format": "oxlint . --fix",
    "format:check": "oxlint ."
  },
  "devDependencies": {
    "oxlint": "^1.24.0",
    "typescript": "^5.9.2"
  },
  "packageManager": "pnpm@10.27.0"
}
