{
  "name": "@alt-stack/durable-streams-core",
  "version": "0.0.1",
  "description": "Protocol primitives for the Durable Streams Protocol: header constants, offset validation, JSON-mode framing, producer state machine, cursor math, ETag helpers, and tagged errors. No I/O.",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest",
    "check-types": "tsc --noEmit"
  },
  "keywords": [
    "durable-streams",
    "streaming",
    "append-only",
    "event-sourcing",
    "http",
    "sse",
    "long-poll"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@alt-stack/result": "workspace:*"
  },
  "devDependencies": {
    "oxlint": "^1.24.0",
    "tsup": "^8.0.0",
    "typescript": "^5.9.2",
    "vitest": "^4.0.3"
  }
}
