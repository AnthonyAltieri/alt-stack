{
  "name": "@alt-stack/durable-streams-server",
  "version": "0.0.1",
  "description": "Framework-agnostic runtime for the Durable Streams Protocol: the stream() builder, Storage interface, and protocol dispatcher. Pair with @alt-stack/server-hono (or another adapter) for routing.",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest",
    "check-types": "tsc --noEmit"
  },
  "keywords": [
    "durable-streams",
    "streaming",
    "append-only",
    "sse",
    "long-poll",
    "alt-stack"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@alt-stack/result": "workspace:*",
    "@alt-stack/durable-streams-core": "workspace:*"
  },
  "peerDependencies": {
    "zod": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "zod": {
      "optional": true
    }
  },
  "devDependencies": {
    "oxlint": "^1.24.0",
    "tsup": "^8.0.0",
    "typescript": "^5.9.2",
    "vitest": "^4.0.3",
    "zod": "^4.0.0"
  }
}
